                 <SocialIcon key={index} link={social.link} icon={social.icon} label={social.label} />\r\n                    ))}\r\n                </Box>\r\n            </Box> */}\r\n        </Box>\r\n    )\r\n}","C:\\ReactNative\\fozzy\\src\\info\\Info.js",[],[],"C:\\ReactNative\\fozzy\\src\\components\\fozzy\\EmojiBullet.js",[],[],"C:\\ReactNative\\fozzy\\src\\components\\myfamily\\Terminal.js",[],[],{"ruleId":"55","severity":1,"message":"56","line":1,"column":17,"nodeType":"57","messageId":"58","endLine":1,"endColumn":25},{"ruleId":"55","severity":1,"message":"59","line":2,"column":8,"nodeType":"57","messageId":"58","endLine":2,"endColumn":13},{"ruleId":"55","severity":1,"message":"60","line":3,"column":8,"nodeType":"57","messageId":"58","endLine":3,"endColumn":16},{"ruleId":"55","severity":1,"message":"61","line":4,"column":8,"nodeType":"57","messageId":"58","endLine":4,"endColumn":10},{"ruleId":"55","severity":1,"message":"62","line":6,"column":10,"nodeType":"57","messageId":"58","endLine":6,"endColumn":14},{"ruleId":"55","severity":1,"message":"63","line":7,"column":8,"nodeType":"57","messageId":"58","endLine":7,"endColumn":18},"no-unused-vars","'useState' is defined but never used.","Identifier","unusedVar","'Style' is defined but never used.","'Terminal' is defined but never used.","'me' is defined but never used.","'info' is defined but never used.","'classNames' is defined but never used."]